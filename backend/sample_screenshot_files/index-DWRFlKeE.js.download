quired",id:"qpN5QXS3OW"}),description:t.jsx(zE,{defaultMessage:"Cowork requires a Mac with Apple Silicon (M1 or later). Intel-based Macs are not currently supported.",id:"pB+VXtyYcB"})};case"unsupported_os_version":return{title:t.jsx(zE,{defaultMessage:"{platform} update required",id:"1dBMFaZe94",values:{platform:Od()?"Windows":Dd()?"Linux":"macOS"}}),description:s||(Od()?t.jsx(zE,{defaultMessage:"Cowork requires Windows 10 build 2004 or later. Update your operating system to use this feature.",id:"7BkU20KRFT"}):Dd()?t.jsx(zE,{defaultMessage:"Cowork requires a newer Linux distribution. Update your operating system to use this feature.",id:"FUSut23kcP"}):t.jsx(zE,{defaultMessage:"Cowork requires macOS 14.0 (Sonoma) or later. Update your operating system to use this feature.",id:"jOY1Gy+4Ti"}))};case"msix_required":return{title:t.jsx(zE,{defaultMessage:"Reinstall required",id:"/9flobnPjq"}),description:t.jsx(zE,{defaultMessage:"Cowork requires Claude Desktop to be installed via a modern installer",id:"2QF7xrKrSb"}),action:{label:t.jsx(zE,{defaultMessage:"Reinstall",id:"AQkpi3vGmC"}),href:"https://claude.com/download"}};case"disabled_by_enterprise":case"disabled_by_user":return{title:t.jsx(zE,{defaultMessage:"Feature disabled",id:"9QHy+wVPnn"}),description:t.jsxs(t.Fragment,{children:[t.jsx(zE,{defaultMessage:"This feature is not currently enabled.",id:"rlYXer5sSI"}),s&&` ${s}`]})};case"hcs_not_available":return{title:t.jsx(zE,{defaultMessage:"Virtual Machine Platform not available",id:"yjT816WO9C"}),description:t.jsx(zE,{defaultMessage:"Claude's workspace requires the Virtual Machine Platform on Windows. Enable this feature, then restart.",id:"iep0DbgP9t"})};case"virtualization_not_available":return{title:t.jsx(zE,{defaultMessage:"Virtualization not available",id:"5GBjSsN9NR"}),description:Od()?t.jsx(zE,{defaultMessage:"Claude's workspace requires hardware virtualization. Enable virtualization in your computer's BIOS/UEFI settings, then restart.",id:"sp6+8env02"}):t.jsx(zE,{defaultMessage:"Cowork requires hardware virtualization. This device does not support it. If you are running inside a virtual machine, you might need to enable nested virtualization.",id:"ku/nJbM87i"})};case"kvm_permission_denied":case"virtualization_tools_missing":case"vhost_vsock_module_missing":return{title:t.jsx(zE,{defaultMessage:"Virtualization isn't fully set up",id:"06i4ZwGxUR"}),description:s||t.jsx(zE,{defaultMessage:"Cowork's local virtual machine needs additional setup on this device.",id:"BLsCcK7SFI"})};case"virtualization_entitlement_missing":return{title:t.jsx(zE,{defaultMessage:"Invalid installation",id:"Vkjh8SA/t8"}),description:t.jsx(zE,{defaultMessage:"Claude's installation appears to be corrupted. Reinstall Claude from claude.com/download to use this feature.",id:"oqcioCyuAP"})};default:return null}}(e,s);if(!n)return null;const{title:a,description:i}=n;return t.jsx("div",{role:"status",className:"bg-bg-200 border-0.5 border-border-400 rounded-xl p-4 w-full max-w-2xl mx-auto mb-3",children:t.jsxs("div",{className:"flex items-start gap-3",children:[t.jsx("div",{className:"flex items-center justify-center pl-1.5 pt-0.5",children:t.jsx(gT,{className:"w-5 h-5 text-text-300 shrink-0",weight:"fill"})}),t.jsxs("div",{className:"flex flex-col gap-1",children:[t.jsx("span",{className:"text-sm font-medium text-text-000",children:a}),t.jsx("span",{className:"text-sm text-text-200",children:i})]})]})})});const y5=i(Fd());var b5,v5;const w5=i(function(){if(v5)return b5;v5=1;const e=zd();return b5=(t,s,n)=>e(s,t,n)}()),j5={releases:JSON.parse('[{"version":"1.15962.1","date":"2026-06-26","entries":[{"surface":"3p","kind":"fix","text":"Fixed locally-configured stdio MCP servers being refused in third-party deployments that don\'t use MDM."},{"surface":"3p","kind":"fix","text":"Fixed third-party MCP connectors disconnecting on every app restart when the OAuth provider returns a non-standard refresh response."},{"surface":"3p","kind":"fix","text":"Fixed Microsoft 365 brokered sign-in failing with \\"No reply address provided\\" on managed Macs."}]},{"version":"1.15962.0","date":"2026-06-25","entries":[{"surface":"general","kind":"fix","text":"Fixed a crash on launch caused by an unusually large saved session."},{"surface":"general","kind":"fix","text":"Fixed the conversation jumping and the Progress panel flashing when opening a completed task."},{"surface":"general","kind":"improvement","text":"Improved keyboard navigation: a message\'s action buttons are now a single Tab stop, with arrow keys to move between them."},{"surface":"code","kind":"fix","text":"Fixed high background CPU usage when several Code sessions were open in the same large repository."},{"surface":"code","kind":"fix","text":"Fixed people without a Claude Code seat being sent to the marketing site from `/code`; they now see an in-app organization switcher."},{"surface":"code","kind":"feat","text":"Added support for custom cron expressions when scheduling local routines."},{"surface":"code","kind":"feat","text":"Added \\"Open in VS Code\\", \\"Open in Cursor\\", and similar actions to the file panel, file tree, plan panel, titlebar, and sidebar in SSH sessions."},{"surface":"code","kind":"fix","text":"Fixed attachment cards for files that exist only inside a session doing nothing when clicked; they now open in the File pane, lightbox, Preview pane, or Files browser."},{"surface":"code","kind":"feat","text":"Added a \\"Load more\\" button to the All sessions list for people with many sessions."},{"surface":"cowork","kind":"fix","text":"Fixed workspace setup repeatedly failing with the same checksum error after a corrupted download, until the cache was cleared."},{"surface":"cowork","kind":"fix","text":"Fixed Cowork sessions losing their project after restarting the app."},{"surface":"cowork","kind":"feat","text":"Added a one-time prompt before Claude runs a dynamic workflow, explaining what workflows do."},{"surface":"cowork","kind":"improvement","text":"Improved the time it takes to start a session."},{"surface":"3p","kind":"feat","text":"Added a managed `websearch` built-in tool so self-hosted deployments can search the web. Admins configure Brave, Tavily, Exa, or a custom endpoint in managed config, and it is available in both the Cowork and Code tabs."},{"surface":"3p","kind":"feat","text":"Added an `otlpContentCapture` managed setting that lets admins opt in to sending specific categories of unredacted content \u2014 user prompts, assistant responses, tool inputs, tool outputs, and raw API request/response bodies \u2014 to their OTLP collector."},{"surface":"3p","kind":"improvement","text":"Updated the Microsoft 365 built-in connector\'s `scope` field to accept `MailboxSettings.Read`."},{"surface":"3p","kind":"fix","text":"Fixed managed connectors that lost their connection staying broken with failing tool calls; they now reconnect automatically on the next tool call, including from newly started conversations, and show a message if reconnecting fails."},{"surface":"3p","kind":"fix","text":"Fixed Microsoft 365 connector sign-in failing on Windows because of a broker error."},{"surface":"3p","kind":"fix","text":"Fixed a sign-in loop when your organization\'s gateway denies access; the app now shows \\"Access denied\\" and points you to your administrator."},{"surface":"3p","kind":"fix","text":"Fixed the selected model reverting after restarting the app and resuming a session."},{"surface":"3p","kind":"feat","text":"Added a `disableBundledSkills` managed config key that turns off Claude Code\'s bundled skills and workflows (such as `deep-research`) on that device."}]},{"version":"1.15200.0","date":"2026-06-23","entries":[{"surface":"code","kind":"feat","text":"Added an inline card for multiple-choice questions from Claude, so you can pick an option and step through each question before your choices are sent as a single reply."},{"surface":"code","kind":"fix","text":"Fixed the app crashing shortly after opening the Code tab when local session history files are very large."},{"surface":"code","kind":"fix","text":"Fixed the integrated terminal eventually failing to open new shells after the app had been running for several days on macOS."},{"surface":"code","kind":"fix","text":"Fixed forked sessions not carrying over pull requests from the original conversation, and pull request rows staying marked as closed after being reopened on GitHub."},{"surface":"code","kind":"fix","text":"Fixed the @-mention dropdown, side-chat panel, and plan-comment popover rendering, resizing, and dismissing in the wrong window when a session is opened in its own window."},{"surface":"code","kind":"fix","text":"Fixed an extra tab opening in the system browser when navigating with the Artifacts pane open."},{"surface":"cowork","kind":"feat","text":"Added the ability to delete Cowork sessions from the sidebar, recents, and Spaces views."},{"surface":"3p","kind":"feat","text":"Published the v2 bootstrap-response JSON schema (nested format). The v1 flat schema remains supported."},{"surface":"3p","kind":"improvement","text":"Removed support for installing connector extensions from local `.mcpb` and `.dxt` files."},{"surface":"3p","kind":"fix","text":"Fixed the Setup panel being locked when only the auto-update policy was deployed via MDM."},{"surface":"3p","kind":"fix","text":"Fixed connectors configured by your organization not appearing until restart after first sign-in."},{"surface":"3p","kind":"fix","text":"Fixed the model picker dropping to \\"Default model\\" mid-session when a gateway\'s model-list response was temporarily degraded."}]},{"version":"1.14271.0","date":"2026-06-18","entries":[{"surface":"general","kind":"fix","text":"Fixed the app prompting you to sign in again every day when your claude.ai session was more than a day old."},{"surface":"general","kind":"fix","text":"Fixed Claude Design links in chat navigating the app in place instead of opening Claude Design."},{"surface":"general","kind":"fix","text":"Fixed the app showing a blank window when a network proxy redirects the connection to Claude."},{"surface":"code","kind":"improvement","text":"Changed routines to count against your regular usage limits instead of a separate daily included-run limit, and removed the included-runs indicator."},{"surface":"code","kind":"improvement","text":"Updated the model picker to show restricted models as non-selectable with an explanatory badge, and to reflect your organization\'s allowed default model."},{"surface":"code","kind":"fix","text":"Fixed HTML and SVG file previews showing black text on a dark background in dark mode."},{"surface":"code","kind":"fix","text":"Fixed menus and popovers opening behind the preview panel."},{"surface":"cowork","kind":"fix","text":"Fixed Claude in Chrome file uploads failing for files in the session\'s shared folders and outputs."},{"surface":"cowork","kind":"fix","text":"Fixed scheduled tasks leaving earlier processes running after each scheduled run."},{"surface":"cowork","kind":"fix","text":"Fixed Windows file paths showing garbled characters in the folder access approval card, and reduced unnecessary folder access denials when allowed workspace folders are configured."},{"surface":"3p","kind":"improvement","text":"(breaking) Changed the `chatCodeExecutionEnabled` managed configuration key to `chatAdvancedFileAnalysisEnabled`. It still lets Claude analyze attached files such as spreadsheets and presentations by running code in a sandbox scoped to the session\'s attachments, and remains off by default. Update any managed configuration that sets the old key."},{"surface":"3p","kind":"improvement","text":"Deprecated the `betaFeaturesEnabled` managed configuration key; use the per-feature keys `chatTabEnabled` and `chatAdvancedFileAnalysisEnabled` instead. The Beta label in the Setup window is now informational only, and the Beta label has been removed from the built-in Microsoft 365 connector presets."},{"surface":"3p","kind":"feat","text":"Added the `inferenceSessionLifetimeSec` managed configuration key. Set it to your identity provider\'s session lifetime to show users a re-authenticate reminder before their sign-in expires."},{"surface":"3p","kind":"feat","text":"Added `~` and environment variable expansion (such as `%APPDATA%` and `%OneDriveCommercial%`) to the `allowedWorkspaceFolders` setting, so folder paths can vary per user."},{"surface":"3p","kind":"feat","text":"Added a per-folder pre-select option to `allowedWorkspaceFolders` so an administrator-configured folder can appear as a ready chip when users start a new task, and removed the \\"Create workspace folder?\\" prompt for administrator-configured folders."}]},{"version":"1.13576.0","date":"2026-06-16","entries":[{"surface":"general","kind":"improvement","text":"Improved find-in-page to search the entire session transcript instead of only the text scrolled into view, and the find bar now reliably takes keyboard focus when opened."},{"surface":"general","kind":"feat","text":"Added a unified Artifacts view that lists your chat, Code, and Cowork artifacts in one searchable place, with a \\"New artifact\\" menu and a \\"Filter by\\" control to narrow the list by source."},{"surface":"general","kind":"fix","text":"Fixed keyboard shortcut conflicts failing silently. Assigning a shortcut already held by another app now tells you and keeps your previous shortcut working, and Quick Entry registration errors now appear in Settings."},{"surface":"general","kind":"fix","text":"Fixed the first-run notification explaining that Claude keeps running in the notification area never appearing on Windows."},{"surface":"code","kind":"feat","text":"Added running dev servers to the Background tasks panel, with stop and open-preview actions."},{"surface":"code","kind":"improvement","text":"Improved the Code file viewer: images, video, and audio now play inline instead of showing as text, and Markdown, CSV, and image files refresh automatically when Claude edits them."},{"surface":"code","kind":"improvement","text":"Updated the model picker. The three headline models appear at the top level with older models and context-size variants under \\"More models\\", each model shows a capability description, and currently-unavailable models appear disabled instead of failing when selected."},{"surface":"code","kind":"improvement","text":"Updated the in-session artifact panel: switch between a session\'s published artifacts from the title dropdown, see when an artifact was last updated, copy a share link, and open, share, or delete the artifact from the overflow menu."},{"surface":"code","kind":"improvement","text":"Changed the Code sessions tab from \\"Projects\\" to \\"All sessions\\". It now lists your non-project sessions alongside project sessions and adds a multi-select Environment filter."},{"surface":"code","kind":"fix","text":"Fixed pull request status checks. Failures now show a small warning indicator on the branch row instead of repeated error popups, the \\"status couldn\'t be checked\\" warning appears less often and can always be dismissed, and only GitHub CLI sign-in problems still raise a notification."},{"surface":"cowork","kind":"fix","text":"Fixed corrupt plugin downloads crashing or hanging the app."},{"surface":"cowork","kind":"fix","text":"Fixed skills sometimes staying on an older version after being edited until toggled off and on."},{"surface":"3p","kind":"feat","text":"Added the Chat tab as a beta feature controlled by the `chatTabEnabled` managed configuration key. The separate `chatCodeExecutionEnabled` key lets Claude analyze attachments and create files such as spreadsheets and presentations by running code in an isolated sandbox scoped to the session\'s attachments, and is off by default."},{"surface":"3p","kind":"feat","text":"Added the `betaFeaturesEnabled` managed configuration key. Setting it to false disables every beta feature in the deployment, including the Chat tab."},{"surface":"3p","kind":"feat","text":"Added Bedrock Mantle as an inference provider option. It reuses the existing `inferenceBedrockRegion` and `inferenceBedrockBaseUrl` managed configuration keys and authenticates with a bearer token or a credential helper."},{"surface":"3p","kind":"feat","text":"Added `anthropicFamilyTier` and `isFamilyDefault` to managed `inferenceModels` entries. Tag each configured model with the Claude tier it stands in for so tier shortcuts like opus and sonnet resolve to your configured model IDs instead of the canonical names your provider may not route."},{"surface":"3p","kind":"feat","text":"Added the `inferenceBedrockAwsCliPath` managed configuration key to set the AWS CLI\'s absolute path. This fixes aws sso login failing when the app is launched from Finder on macOS and the CLI is not on the default search path."},{"surface":"3p","kind":"fix","text":"Fixed Google Workspace connectors never starting their OAuth sign-in. The MCP client identifier the app sends to connected servers is now `claude-desktop-3p`, changed from `custom3p-desktop`, so update any MCP server allowlists or log filters that match the old value."},{"surface":"3p","kind":"fix","text":"Fixed the managed Tool policy `*` entry being ignored. It now applies as the default for any tool not listed by name."},{"surface":"3p","kind":"fix","text":"Fixed organization plugins sometimes not opening from the Directory right after launch or update."},{"surface":"3p","kind":"fix","text":"Fixed several connection and sign-in issues: Bedrock sessions now prompt to sign in again after AWS IAM Identity Center expires instead of failing with repeated credential errors, remote MCP connectors no longer stay Connected after a non-refreshable access token expires, the connection test now passes against gateways that optionally request a TLS client certificate, signing in after signing out no longer needs a double click, and sign-in recovery no longer uses stale configuration after a server-side update or leaves the model picker empty until restart."}]},{"version":"1.12603.1","date":"2026-06-11","entries":[{"surface":"general","kind":"feat","text":"Added Find Next and Find Previous keyboard shortcuts to in-app search."},{"surface":"general","kind":"fix","text":"Fixed preview panes stealing keyboard focus from the chat input when they reloaded or navigated."},{"surface":"general","kind":"fix","text":"Fixed sessions failing to start after your sign-in expired \u2014 the app now prompts you to sign in again."},{"surface":"code","kind":"feat","text":"Added the Files panel to remote and SSH sessions \u2014 search the session\'s files and open them in the viewer \u2014 plus a Show in Files button in the file viewer."},{"surface":"code","kind":"feat","text":"Added a running-tasks button to the activity indicator that opens the Tasks panel, and Bash rows in the Background tasks panel now open to show their output, including a live tail while the command runs."},{"surface":"code","kind":"fix","text":"Fixed SSH sessions: forking no longer opens an empty conversation, and connections no longer fail with \\"Failed to upload file\\" errors on remotes first set up by early-2026 versions of the app."},{"surface":"code","kind":"fix","text":"Fixed renaming a session while its title was still generating \u2014 the generated title no longer overwrites the name you set."},{"surface":"code","kind":"fix","text":"Fixed the Pull Requests view showing \\"No open pull requests\\" when GitHub isn\'t connected \u2014 it now prompts you to connect."},{"surface":"code","kind":"feat","text":"Added model-picker memory \u2014 the picker now remembers your last model choice."},{"surface":"cowork","kind":"fix","text":"Fixed scheduled tasks firing many duplicate runs at once when the computer wakes from sleep."},{"surface":"cowork","kind":"fix","text":"Fixed remote sessions re-prompting for access to folders you had already trusted."},{"surface":"cowork","kind":"fix","text":"Fixed plugins becoming corrupted when they synced while you switched accounts."},{"surface":"3p","kind":"feat","text":"Added the built-in Microsoft 365 connector \u2014 admins can configure it from the Setup window\'s server presets. Users sign in through their browser, and Claude can search and read Microsoft 365 mail, calendar, OneDrive, and SharePoint. It requests read-only access by default; admins can grant additional read scopes, such as Teams channel messages and meeting transcripts, with the managed server entry\'s scope setting."},{"surface":"3p","kind":"improvement","text":"Deprecated the \\"sso\\" value for the inferenceGatewayAuthScheme managed configuration key in favor of inferenceCredentialKind \\"interactive\\" \u2014 existing configurations keep working and log a deprecation warning."},{"surface":"3p","kind":"feat","text":"Added the inferenceVertexOAuthLoginHint managed configuration key to pre-fill the Google account chooser when signing in to Vertex AI, so users in organizations federated to a third-party identity provider land on the right account automatically."}]},{"version":"1.11847.5","date":"2026-06-09","entries":[{"surface":"general","kind":"fix","text":"Fixed Clear Cache and Restart signing you out instead of just clearing caches."},{"surface":"general","kind":"fix","text":"Fixed mouse back and forward buttons not navigating on macOS for mice managed by driver software like Logitech Options+, and added trackpad swipe navigation."},{"surface":"general","kind":"fix","text":"Fixed organization plugins sometimes failing to open right after app launch, and the plugin directory now offers Install again after an uninstall."},{"surface":"general","kind":"fix","text":"Fixed connector, Chrome extension, and plugin toggles in the composer\'s \\"+\\" menu not responding when you click directly on the switch."},{"surface":"general","kind":"fix","text":"Fixed an issue where signing in could leave the app unable to start sessions until it was restarted."},{"surface":"general","kind":"fix","text":"Fixed shell-exported custom request headers not reaching Claude Code sessions."},{"surface":"code","kind":"fix","text":"Fixed Claude losing its coding instructions, file-link formatting, and worktree context after a session resumed from idle."},{"surface":"code","kind":"fix","text":"Fixed the preview pane sometimes connecting to an unrelated dev server that was already using the configured port, and it now reopens the dev server you last picked for each project."},{"surface":"code","kind":"improvement","text":"Improved responsiveness in Code sessions: smoother streaming of long code blocks, quicker side-panel shortcuts, and less delay opening cloud sessions with many screenshots."},{"surface":"code","kind":"fix","text":"Fixed popovers, dialogs, and the rewind picker not appearing \u2014 and typed characters jumping to the end of the composer \u2014 when a Code session is opened in its own window."},{"surface":"code","kind":"fix","text":"Fixed the slash-command menu opening behind the side chat panel."},{"surface":"code","kind":"fix","text":"Fixed the source-branch picker showing nothing for SSH sessions with worktree enabled."},{"surface":"cowork","kind":"feat","text":"Added a \\"Free Up Cowork Disk Space\\" option under Help > Troubleshooting, and Cowork now cleans up caches and old temporary files automatically when its workspace disk runs low."},{"surface":"cowork","kind":"improvement","text":"Improved the read/unread toggle on sidebar sessions: it now works on the currently open session, has a larger click target, and shows a tooltip describing what a click will do."},{"surface":"3p","kind":"feat","text":"Added support for the Fable model family, and for Mythos where your organization has access."},{"surface":"3p","kind":"fix","text":"Fixed sign-in failing with external identity providers that reject the offline_access scope \u2014 admins can now disable the automatic append."}]},{"version":"1.11187.4","date":"2026-06-05","entries":[{"surface":"general","kind":"fix","text":"Fixed reinstalling Claude on Windows failing after an uninstall when IT had installed it for all users."},{"surface":"general","kind":"fix","text":"Fixed the app not starting automatically at login on Windows."},{"surface":"general","kind":"feat","text":"Added a banner when an update fails to install, instead of failing silently."},{"surface":"general","kind":"fix","text":"Fixed built-in connectors staying disconnected after a crash \u2014 existing sessions now reconnect them automatically, and disconnecting a built-in connector now signs it out and keeps it disconnected across restarts."},{"surface":"code","kind":"feat","text":"Added math rendering for inline and block expressions in Claude Code transcripts."},{"surface":"code","kind":"feat","text":"Added Ultracode to the effort slider, which selects the highest effort level and turns on dynamic workflows for the session."},{"surface":"code","kind":"feat","text":"Added drag-to-reorder and A\u2192Z sorting for projects in the Claude Code sidebar."},{"surface":"code","kind":"feat","text":"Added triple-click to select a whole code block, plus right-click menu actions to copy a code block or inline code, in Claude Code transcripts."},{"surface":"code","kind":"fix","text":"Fixed resuming Code sessions when the working folder had moved or been deleted \u2014 sessions saved with a ~ path no longer show as missing or re-prompt for trust, and a deleted remote folder now reports clearly and offers a Fork session button instead of retrying in a loop."},{"surface":"cowork","kind":"feat","text":"Added a low-disk-space warning before Cowork downloads the files it needs to run."},{"surface":"cowork","kind":"feat","text":"Added in-session effort and thinking controls for local Cowork projects."},{"surface":"cowork","kind":"improvement","text":"Updated the New project folder picker to default to your Claude data folder (~/Claude/Projects) instead of ~/Documents."},{"surface":"cowork","kind":"fix","text":"Fixed Claude reporting that a skill was updated when the change was never saved to your account."},{"surface":"cowork","kind":"fix","text":"Fixed the /schedule command in Cowork showing as unavailable."},{"surface":"3p","kind":"fix","text":"Fixed managed connectors and SSO sign-in requesting broader OAuth scopes than the administrator configured."},{"surface":"3p","kind":"fix","text":"Fixed three Bedrock sign-in and session issues: SSO sign-in failing behind corporate proxies that intercept secure traffic, expired SSO tokens prompting a new sign-in every hour instead of refreshing automatically, and resumed sessions failing on their first message."}]}]')}.releases,k5={code:new Set(["general","code"]),cowork:new Set(["general","cowork"])};function M5(e){const t=k5[e],s=new Set(t),n=j5.map(e=>({version:e.version,date:e.date,items:e.entries.filter(e=>s.has(e.surface)).map(e=>({kind:e.kind,text:e.text}))})).filter(e=>e.items.length>0),a=new Set(j5.filter(e=>e.entries.some(e=>t.has(e.surface))).map(e=>e.version)),i=new Map(n.map(e=>[e.version,e]));if("cowork"!==e)for(const r of _5){if(a.has(r.version))continue;const e=i.get(r.version);i.set(r.version,e?{...e,items:[...e.items,...r.items]}:r)}return[...i.values()].filter(e=>Bd(e.version)).sort((e,t)=>w5(e.version,t.version))}const _5=[{version:"1.11187.0",date:"2026-06-04",items:[{kind:"improvement",text:BE({defaultMessage:"Click a filename on an Edited or Wrote row to open that file in the diff pane",id:"uJac4DtLEH"})},{kind:"improvement",text:BE({defaultMessage:"Project rows in the Recents sidebar expand with a click, and a hover-revealed `View project` button opens the project page",id:"Adm40w2OOS"})},{kind:"improvement",text:BE({defaultMessage:"When a remote session's working folder has been deleted, `Fork session` recovers it into a fresh worktree",id:"FKMFf4iqY+"})},{kind:"fix",text:BE({defaultMessage:"The floating side chat ([[cmd+;]]) remembers where you placed and sized it",id:"yxzcnV4kDy"})},{kind:"fix",text:BE({defaultMessage:"[[cmd+k]] finds sessions you started since opening the app, and searches branches inside folders",id:"os5Efgh+1R"})},{kind:"fix",text:BE({defaultMessage:"`Add plugin` from the + menu opens straight to the installable plugin list",id:"BWNg2tVBBL"})},{kind:"fix",text:BE({defaultMessage:"Rename from the sidebar's right-click menu edits the name in place",id:"XRbDTrjI0c"})},{kind:"fix",text:BE({defaultMessage:"Sessions with an open draft PR no longer show or sort as closed",id:"J8WyagGCb5"})},{kind:"fix",text:BE({defaultMessage:"Dropdowns near the top of the window are clickable instead of dragging the window",id:"FsajkwOAiZ"})},{kind:"fix",text:BE({defaultMessage:"SSH session setup works when the remote home directory is on a network filesystem",id:"huzigEoZJv"})},{kind:"fix",text:BE({defaultMessage:"Tables in popout windows use the right font size",id:"ITKXJOdd9C"})}]},{version:"1.10628.0",date:"2026-06-02",items:[{kind:"feat",text:BE({defaultMessage:"Choose effort with a slider next to the model picker",id:"uYLQ5lDLZu"})},{kind:"feat",text:BE({defaultMessage:"Mark a waiting session as completed from the sidebar's right-click menu \u2014 clears the yellow dot without sending a reply",id:"4HrerxXUg5"})},{kind:"improvement",text:BE({defaultMessage:"When the model is overloaded, pick a different one right from the error card's retry menu",id:"giU3LRQe8Q"})},{kind:"improvement",text:BE({defaultMessage:"The Files panel stays open when you switch between sessions",id:"Jdr9gPxUIc"})},{kind:"improvement",text:BE({defaultMessage:"Usage-limit notices now say which limit you hit and when it resets",id:"0bIJknc5LK"})},{kind:"improvement",text:BE({defaultMessage:"Press a number key to pick an option when Claude asks a question",id:"icn8CM+0cV"})},{kind:"fix",text:BE({defaultMessage:"Opening a very large repository no longer crashes on startup",id:"Vqd9xnOl2k"})},{kind:"fix",text:BE({defaultMessage:"The diff panel and file previews work in SSH sessions",id:"gC9+SjQopv"})},{kind:"fix",text:BE({defaultMessage:"Sessions in their own window stay responsive when the main window is hidden",id:"VHhN1KfmCH"})},{kind:"fix",text:BE({defaultMessage:"Archiving or deleting a session works while it's starting up or responding",id:"hEM4asyIjl"})}]},{version:"1.9659.0",date:"2026-05-28",items:[{kind:"feat",text:BE({defaultMessage:"Claude Opus 4.8 is now available in the model picker",id:"BBdIiDX7hr"})},{kind:"feat",text:BE({defaultMessage:"Dynamic workflows let Claude fan out to many subagents on a single task",id:"8By5nlWG7I"})},{kind:"feat",text:BE({defaultMessage:"Your `WorktreeCreate` and `WorktreeRemove` hooks run for local sessions too \u2014 jj and Sapling setups can use worktree isolation",id:"de6C2Wzbse"})},{kind:"fix",text:BE({defaultMessage:"Searching file contents with `?` works for folders that aren't git repos",id:"CjsWsZhIqS"})},{kind:"fix",text:BE({defaultMessage:"Agents you define in your project's `.claude/agents` show up in the `@`-mention picker \u2014 and new ones appear without a restart",id:"JjAk5QHGza"})},{kind:"fix",text:BE({defaultMessage:"The PR bar finds your open PR even when your local branch name doesn't match the remote's",id:"dN1nhuij65"})},{kind:"fix",text:BE({defaultMessage:"Local video attachments play in the lightbox",id:"6p+YJwQX1o"})},{kind:"fix",text:BE({defaultMessage:"Starting a session on a branch works with macOS's built-in git",id:"VZeCi0uoZQ"})}]},{version:"1.9255.0",date:"2026-05-26",items:[{kind:"feat",text:BE({defaultMessage:"Split view now tiles into an adaptive grid \u2014 fit more sessions on a wide screen",id:"8vlKwS/pfy"})},{kind:"feat",text:BE({defaultMessage:"`/rename` renames the current session",id:"1iTX3zl2VF"})},{kind:"feat",text:BE({defaultMessage:"`/compact` now shows a marker in the transcript where context was compacted",id:"DAJYQ+55MZ"})},{kind:"feat",text:BE({defaultMessage:"Get a desktop notification when a routine run fails",id:"EHpObemtru"})},{kind:"improvement",text:BE({defaultMessage:"Remote Control shows as a badge in the title bar \u2014 click it to turn on or off",id:"M5bEHfdTTK"})},{kind:"improvement",text:BE({defaultMessage:"Click an image path in a response to preview it, even when it's outside your project folder",id:"iKUOEsCesf"})},{kind:"improvement",text:BE({defaultMessage:"Files you reference with `@` show as chips in the transcript, not just videos",id:"yNWdRZLhMh"})},{kind:"improvement",text:BE({defaultMessage:"Queued messages collapse into a stack \u2014 click to expand",id:"CCGNwmhrOs"})},{kind:"improvement",text:BE({defaultMessage:"Bash commands in the transcript are syntax-highlighted",id:"SzTj8drdXm"})},{kind:"improvement",text:BE({defaultMessage:"Your most recent sessions open faster from the sidebar",id:"XjwwQZQC/4"})},{kind:"fix",text:BE({defaultMessage:"Trackpad scrolling works over code and diff blocks",id:"kVrDy/v1HF"})},{kind:"fix",text:BE({defaultMessage:"The transcript stays where you scrolled instead of snapping back to the bottom",id:"rxO0yeSTDT"})},{kind:"fix",text:BE({defaultMessage:"Cancelling a queued message no longer interrupts the turn in progress",id:"P63xgHSKex"})},{kind:"fix",text:BE({defaultMessage:"Sessions with uncommitted changes are no longer auto-archived",id:"pNZUCYa4jA"})}]},{version:"1.8555.1",date:"2026-05-22",items:[{kind:"feat",text:BE({defaultMessage:"Open a session in its own window to work on sessions side by side \u2014 drag it out from the sidebar, or [[cmd+click]] it",id:"ZGvkX6TY8M"})},{kind:"feat",text:BE({defaultMessage:"Auto mode is now available on the Pro plan \u2014 Sonnet 4.6 is now supported, alongside Opus 4.7",id:"QnA8VUIvVj"})}]},{version:"1.8555.0",date:"2026-05-21",items:[{kind:"feat",text:BE({defaultMessage:"Videos you attach appear as chips in the transcript \u2014 click to play",id:"iRvW/9oStG"})},{kind:"feat",text:BE({defaultMessage:"Click a `#L5-L20` link in a response to highlight those lines in the file panel",id:"jPM3XrqpC3"})},{kind:"improvement",text:BE({defaultMessage:"`file://` paths in responses are now clickable",id:"fCqsyH2TG3"})},{kind:"fix",text:BE({defaultMessage:"Remote sessions reconnect on their own after sleep or network changes",id:"ZWsDyQeFPt"})}]},{version:"1.8089.0",date:"2026-05-19",items:[{kind:"feat",text:BE({defaultMessage:"Group sessions by PR state from the filter icon at the top of the sidebar",id:"X707sOR++o"})},{kind:"feat",text:BE({defaultMessage:"[[cmd+u]] attaches a file from your computer",id:"qUTTUrFL4F"})},{kind:"improvement",text:BE({defaultMessage:"Sessions remember your scroll position when you come back to them",id:"jfGIZALMiO"})}]},{version:"1.7196.0",date:"2026-05-15",items:[{kind:"feat",text:BE({defaultMessage:"Pick your code font and theme in `Settings \u2192 Claude Code \u2192 Appearance`",id:"R4cKoaRG3c"})},{kind:"feat",text:BE({defaultMessage:"Get a desktop notification when Claude finishes while you're in another app",id:"EJgFVunmTS"})},{kind:"feat",text:BE({defaultMessage:"[[ctrl+]]] and [[ctrl+[]] cycle focus between split panes",id:"1pDTicCdea"})},{kind:"feat",text:BE({defaultMessage:"Move a local session to the cloud from its `\u2022\u2022\u2022` menu so it keeps running when you close your laptop",id:"2Mt/gDql/P"})},{kind:"feat",text:BE({defaultMessage:"`/usage` shows your token usage for the current session inline",id:"MJeNpHWSBI"})},{kind:"fix",text:BE({defaultMessage:"Dotfiles show up in the file tree and `@`-mention search",id:"ZloNHabIoM"})}]},{version:"1.6608.0",date:"2026-05-07",items:[{kind:"feat",text:BE({defaultMessage:"Create and name your own session groups \u2014 drag sessions in, or right-click a session \u2192 `Move to group`",id:"NAen74+5KK"})},{kind:"feat",text:BE({defaultMessage:"Click any file in the file panel to edit it in place",id:"fKFZn3x9/k"})},{kind:"feat",text:BE({defaultMessage:"Turn on Remote Control for all new local sessions in `Settings \u2192 Claude Code`",id:"BWYONtbtL0"})},{kind:"improvement",text:BE({defaultMessage:"Resolved review comments collapse in the diff view so you can focus on what's open",id:"g8jaGMlx3n"})}]},{version:"1.6259.0",date:"2026-05-05",items:[{kind:"feat",text:BE({defaultMessage:"Attach up to 20 images in a single message for local sessions",id:"AtQI4gQ2Qm"})},{kind:"improvement",text:BE({defaultMessage:'"Always allow" choices now persist after you quit the app',id:"tQkGeo/pLH"})},{kind:"improvement",text:BE({defaultMessage:"Sidebar pins and starred sessions survive sign-out",id:"+qm9S5DZcB"})}]},{version:"1.5354.0",date:"2026-04-29",items:[{kind:"feat",text:BE({defaultMessage:"`/btw` or [[cmd+;]] opens a side chat with Claude without interrupting your main session",id:"oCUtTGiVOc"})},{kind:"feat",text:BE({defaultMessage:"Open multiple terminal tabs in the terminal pane",id:"KpxLln6Tcc"})},{kind:"feat",text:BE({defaultMessage:"Right-click any folder in the file tree \u2192 `Open in terminal`",id:"o93iHAIei0"})},{kind:"feat",text:BE({defaultMessage:"Queue follow-up messages while Claude is still working \u2014 they send automatically when it's ready",id:"FJeVTW7t3g"})},{kind:"feat",text:BE({defaultMessage:"See related and stacked PRs together in the PR bar",id:"nzAlf/Dr9C"})},{kind:"feat",text:BE({defaultMessage:"Sort sessions from the filter icon in the sidebar",id:"bfrtsSnP8t"})},{kind:"feat",text:BE({defaultMessage:"`/feedback` sends feedback about the current session without leaving it",id:"vMDozLqrrm"})}]},{version:"1.4758.0",date:"2026-04-24",items:[{kind:"feat",text:BE({defaultMessage:"Drag, resize, and keyboard-navigate split panes with sessions side by side",id:"JR1Xo64s7i"})},{kind:"feat",text:BE({defaultMessage:"Draw directly on the preview to show Claude what you mean \u2014 click the pencil icon in the preview toolbar",id:"VN6sKZ3xLJ"})},{kind:"feat",text:BE({defaultMessage:"Markdown files render as formatted previews in the file panel",id:"Gls6MqqVlD"})},{kind:"feat",text:BE({defaultMessage:"Right-click any file in the diff tree for `Open`, `Copy path`, and `Attach as context`",id:"s1HEb7obG9"})},{kind:"feat",text:BE({defaultMessage:"Archive or delete several sessions at once from the Recents header menu",id:"oWtfUA9kKn"})}]},{version:"1.3883.0",date:"2026-04-21",items:[{kind:"feat",text:BE({defaultMessage:"`Open in editor` from the diff view or a session's right-click menu",id:"eAyw5h1GYi"})},{kind:"feat",text:BE({defaultMessage:"Right-click any image in a response to `Copy` or `Save` it",id:"Ka5fuL2X+i"})},{kind:"improvement",text:BE({defaultMessage:"`#123` and bare URLs in your messages become clickable links",id:"EBLto6Usbn"})}]},{version:"1.3561.0",date:"2026-04-20",items:[{kind:"feat",text:BE({defaultMessage:"Browse your project's files in a side pane \u2014 fuzzy-find by name, search contents with `?`, [[cmd+f]] to find in file",id:"h9861zcdct"})},{kind:"feat",text:BE({defaultMessage:"`/model` switches the model mid-session",id:"Awv67vzgyK"})},{kind:"feat",text:BE({defaultMessage:"Right-click any message \u2192 `Copy as Markdown` or `Copy link`",id:"XZBHNaDiVC"})},{kind:"feat",text:BE({defaultMessage:"Every folder you've worked in appears under Recent \u2014 click the `+` next to one to start a session there",id:"66GrxvW+G9"})},{kind:"feat",text:BE({defaultMessage:"Right-click a message or select text \u2192 `Attach as context` to reference it in your next message",id:"I6tIchIFGY"})},{kind:"improvement",text:BE({defaultMessage:"Math renders inline in responses",id:"N/ByQVfDc5"})}]},{version:"1.3109.0",date:"2026-04-16",items:[{kind:"feat",text:BE({defaultMessage:"Toggle Fast mode from the model picker on supported models for quicker responses",id:"ADD2IN+/Xo"})},{kind:"improvement",text:BE({defaultMessage:"Your project's `settings.json` model is used by default for new sessions",id:"9CYg800SaU"})}]},{version:"1.2773.0",date:"2026-04-15",items:[{kind:"feat",text:BE({defaultMessage:"`/rewind` steps back to before your last message",id:"GWhWpIE+86"})},{kind:"feat",text:BE({defaultMessage:"Scroll t